# Copy this file to .env.production on your server and edit all values.

APP_DOMAIN=live.example.com
LIVEKIT_DOMAIN=lk.example.com
TURN_DOMAIN=turn.example.com

PORT=3000
ROOM_NAME=friends-screen-room

# Generate long random values before production:
# openssl rand -hex 16
LIVEKIT_API_KEY=prodkey
LIVEKIT_API_SECRET=replace-with-a-long-random-secret

VIEWER_PASSWORD=replace-viewer-password
BROADCASTER_PASSWORD=replace-broadcaster-password
TOKEN_TTL_MINUTES=120

LIVEKIT_URL=wss://lk.example.com
