# Web server
PORT=3000

# Public LiveKit websocket URL used by browsers.
# Local dev with LiveKit on the same computer can use ws://localhost:7880
# Production should use wss://livekit.your-domain.com
LIVEKIT_URL=ws://localhost:7880

# Fixed LiveKit room name for this small private site.
ROOM_NAME=friends-screen-room

# LiveKit API credentials. Must match livekit/livekit.yaml on self-hosting.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Passwords for entering the room.
# Viewer can watch and chat. Broadcaster can also publish screen/mic.
VIEWER_PASSWORD=watch123
BROADCASTER_PASSWORD=live123

# Token lifetime in minutes.
TOKEN_TTL_MINUTES=120
