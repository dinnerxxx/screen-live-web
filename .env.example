# Web server
PORT=3000

# Tencent Cloud TRTC credentials.
# SDKSecretKey must stay on the server. Never put it in public frontend code.
TRTC_SDK_APP_ID=0
TRTC_SDK_SECRET_KEY=replace-with-your-secret-key

# Fixed private room id. Use letters, numbers, hyphen, or underscore.
TRTC_ROOM_ID=scshare-room

# Passwords for entering the room.
# Viewer can watch. Broadcaster can publish screen and send TRTC custom messages.
VIEWER_PASSWORD=watch123
BROADCASTER_PASSWORD=live123

# UserSig lifetime in minutes.
TOKEN_TTL_MINUTES=120
